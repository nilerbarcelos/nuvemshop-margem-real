PORT=3000
NODE_ENV=development
SESSION_SECRET=troque-por-string-aleatoria

# Nuvemshop (Portal de Parceiros)
NUVEMSHOP_CLIENT_ID=
NUVEMSHOP_CLIENT_SECRET=
NUVEMSHOP_REDIRECT_URI=https://seu-app.railway.app/auth/callback

# App URL (usado para redirect)
APP_URL=https://seu-app.railway.app

# Diretório de dados (SQLite). No Railway, use o caminho do volume montado.
# Ex: DATA_DIR=/data  com volume montado em /data
DATA_DIR=./data

# SMTP para alertas e relatório semanal
# Opção gratuita: Gmail com senha de app
# Opção recomendada: Resend (resend.com) - 3000 emails/mês grátis
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@gmail.com
SMTP_PASS=senha-de-app-gmail
SMTP_FROM=Margem Real <seu@gmail.com>
